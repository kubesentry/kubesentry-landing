---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import DashboardMockup from '../components/DashboardMockup.astro';
import InstallSnippet from '../components/InstallSnippet.astro';
import ClusterDiagram from '../components/ClusterDiagram.astro';
import Pricing from '../components/Pricing.astro';

const DOCS = 'https://docs.kubesentry.io';
const GITHUB = 'https://github.com/kubesentry';
---

<Layout>
  <!-- TOP NAV -->
  <header class="border-b border-line">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-5">
      <div class="shrink-0"><Logo /></div>
      <nav class="flex shrink-0 items-center gap-4 sm:gap-6" aria-label="Primary">
        <a
          href={DOCS}
          class="text-sm text-text-dim transition hover:text-text"
        >
          Docs
        </a>
        <a
          href="#pricing"
          class="hidden text-sm text-text-dim transition hover:text-text min-[420px]:block"
        >
          Pricing
        </a>
        <a
          href={GITHUB}
          target="_blank"
          rel="noopener"
          class="hidden text-sm text-text-dim transition hover:text-text sm:block"
        >
          GitHub
        </a>
        <a
          href={`${DOCS}/getting-started/installation/`}
          class="rounded-lg bg-accent px-3.5 py-1.5 font-display text-sm font-semibold text-bg transition hover:bg-accent-dim"
        >
          Install
        </a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 pb-16 pt-20 sm:pt-28">
      <!-- Availability marker -->
      <div
        class="mb-8 inline-flex items-center gap-2 rounded-full border border-line bg-bg-elevated/60 px-4 py-1.5 text-xs font-medium backdrop-blur-sm"
        style="animation: fadeInUp 0.6s 0.05s both;"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
        </span>
        <!-- Deliberately no version number: this page lives in a different repo
             from the chart with nothing syncing them, so a hardcoded version
             silently goes stale on every release. `helm search repo kubesentry`
             is always right by construction. -->
        <span class="text-text-dim">
          <span class="text-text">Available now</span>
          <span class="mx-2 text-line">·</span>
          7-day free trial
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="max-w-4xl text-balance font-display text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl"
        style="animation: fadeInUp 0.8s 0.15s both;"
      >
        <span class="text-text">Catch threats in your</span>
        <br />
        <span class="relative inline-block">
          <span class="text-accent">Kubernetes cluster</span>
          <svg
            class="absolute -bottom-2 left-0 w-full"
            viewBox="0 0 400 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M2 9C50 3 150 3 200 6C250 9 350 9 398 4"
              stroke="#00ff9c"
              stroke-width="2"
              stroke-linecap="round"
              opacity="0.4"
            />
          </svg>
        </span>
        <br />
        <span class="text-text">before they catch you.</span>
      </h1>

      <!-- Subheadline -->
      <p
        class="mt-8 max-w-2xl text-balance text-lg leading-relaxed text-text-dim sm:text-xl"
        style="animation: fadeInUp 0.8s 0.3s both;"
      >
        Kernel-level runtime threat detection built on Falco, running entirely
        in your own cluster. No phone-home, no telemetry — nothing leaves
        except the alerts you tell it to send, to the destinations you pick.
      </p>

      <!-- Feature badges -->
      <div
        class="mt-10 flex flex-wrap gap-3"
        style="animation: fadeInUp 0.8s 0.45s both;"
      >
        {
          [
            '⎈ Helm install',
            '🔒 Self-hosted',
            '⚡ Kernel-level (eBPF)',
            '💾 Perpetual license',
            '🔧 No phone home',
          ].map((badge) => (
            <span class="rounded-full border border-line bg-bg-elevated/40 px-4 py-1.5 font-mono text-xs text-text-dim">
              {badge}
            </span>
          ))
        }
      </div>

      <!-- Install + CTAs -->
      <div class="mt-12 max-w-2xl" style="animation: fadeInUp 0.8s 0.6s both;">
        <InstallSnippet />

        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={`${DOCS}/getting-started/installation/`}
            class="rounded-lg bg-accent px-5 py-3 text-center font-display text-sm font-semibold text-bg transition hover:bg-accent-dim"
          >
            Start free trial →
          </a>
          <a
            href={DOCS}
            class="rounded-lg border border-line bg-bg-elevated/40 px-5 py-3 text-center font-display text-sm font-semibold text-text transition hover:border-accent/40 hover:text-accent"
          >
            Read the docs
          </a>
        </div>

        <p class="mt-4 font-mono text-xs text-text-faint">
          Installs in minutes · full product for 7 days · no credit card
        </p>
      </div>
    </div>

    <!-- Dashboard mockup -->
    <div class="relative mx-auto max-w-7xl px-6 pb-32">
      <div class="relative" style="animation: fadeInUp 1s 0.8s both;">
        <!-- Glow behind dashboard -->
        <div
          class="absolute -inset-x-10 -top-10 -bottom-10 bg-gradient-to-b from-accent/10 via-transparent to-transparent blur-3xl"
          aria-hidden="true"
        >
        </div>
        <DashboardMockup />
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="relative border-t border-line py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16">
        <div class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">
          // how it works
        </div>
        <h2
          class="max-w-3xl text-balance font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl"
        >
          From <span class="text-accent">helm install</span> to first alert in under
          5 minutes.
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <!-- Step 1 -->
        <div
          class="group relative overflow-hidden rounded-xl border border-line bg-bg-elevated/30 p-6 transition hover:border-accent/30"
        >
          <div class="mb-6 flex items-center justify-between">
            <span class="font-mono text-xs text-text-faint">01</span>
            <span
              class="rounded-full bg-bg px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-text-dim"
            >
              install
            </span>
          </div>
          <div class="mb-4 overflow-x-auto rounded-lg border border-line bg-bg/60 p-4 font-mono text-sm">
            <div class="whitespace-pre text-text-dim">$ helm install kubesentry \</div>
            <div class="whitespace-pre text-text-dim">&nbsp;&nbsp;&nbsp;&nbsp;kubesentry/kubesentry</div>
          </div>
          <h3 class="mb-2 font-display font-semibold text-text">One-command install</h3>
          <p class="text-sm leading-relaxed text-text-dim">
            Falco + collector + dashboard + alerter — all deployed via one Helm
            chart, on any cluster running a kernel Falco supports.
          </p>
        </div>

        <!-- Step 2 -->
        <div
          class="group relative overflow-hidden rounded-xl border border-line bg-bg-elevated/30 p-6 transition hover:border-accent/30"
        >
          <div class="mb-6 flex items-center justify-between">
            <span class="font-mono text-xs text-text-faint">02</span>
            <span
              class="rounded-full bg-bg px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-text-dim"
            >
              detect
            </span>
          </div>
          <div
            class="mb-4 space-y-1.5 overflow-x-auto rounded-lg border border-line bg-bg/60 p-4 font-mono text-xs"
          >
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-danger"></span>
              <span class="whitespace-nowrap text-text">Reverse shell in pod/payments-api</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-warn"></span>
              <span class="whitespace-nowrap text-text-dim">Crypto miner process</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
              <span class="whitespace-nowrap text-text-dim">Privileged container started</span>
            </div>
          </div>
          <h3 class="mb-2 font-display font-semibold text-text">Curated rules</h3>
          <p class="text-sm leading-relaxed text-text-dim">
            14 KubeSentry rules tuned for low false positives — crypto miners,
            reverse shells, privilege escalation, lateral movement — running on
            top of Falco's default ruleset.
          </p>
        </div>

        <!-- Step 3 -->
        <div
          class="group relative overflow-hidden rounded-xl border border-line bg-bg-elevated/30 p-6 transition hover:border-accent/30"
        >
          <div class="mb-6 flex items-center justify-between">
            <span class="font-mono text-xs text-text-faint">03</span>
            <span
              class="rounded-full bg-bg px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-text-dim"
            >
              alert
            </span>
          </div>
          <div class="mb-4 overflow-x-auto rounded-lg border border-line bg-bg/60 p-4 font-mono text-xs">
            <div class="whitespace-nowrap text-accent">→ Slack</div>
            <div class="mt-1 whitespace-nowrap text-accent">→ Email digest</div>
            <div class="mt-1 whitespace-nowrap text-accent">→ Discord / Teams</div>
            <div class="mt-1 whitespace-nowrap text-text-faint">→ Custom webhook</div>
          </div>
          <h3 class="mb-2 font-display font-semibold text-text">Actionable alerts</h3>
          <p class="text-sm leading-relaxed text-text-dim">
            Critical events fire instantly. Daily digests roll up the noise. Every
            KubeSentry rule ships with triage steps and remediation commands.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT GETS INSTALLED -->
  <ClusterDiagram />

  <!-- WHY -->
  <section class="relative border-t border-line py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">
        // why kubesentry
      </div>
      <h2 class="font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
        Enterprise security <br />
        <span class="text-text-dim line-through decoration-danger/70 decoration-2"
          >at enterprise prices.</span
        >
        <br />
        <span class="text-accent">for €99.</span>
      </h2>
      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-text-dim">
        Datadog. Sysdig. Aqua. Built for enterprises with security teams, and sold as
        subscriptions metered by how much you run — for as long as you run it.
        KubeSentry is built for the rest of us: the five-to-fifty-person engineering
        org with real clusters and nobody whose full-time job is security.
      </p>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-dim">
        You pay once. It runs in your cluster. Nobody meters your hosts.
      </p>
    </div>
  </section>

  <!-- PRICING -->
  <Pricing />

  <!-- FAQ -->
  <section class="relative border-t border-line py-24">
    <div class="mx-auto max-w-3xl px-6">
      <div class="mb-12">
        <div class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">
          // questions
        </div>
        <h2 class="font-display text-4xl font-bold tracking-tight sm:text-5xl">
          You probably want to know.
        </h2>
      </div>

      <div class="space-y-4">
        {
          [
            {
              q: 'Is this just a Falco wrapper?',
              a: "Falco is the engine — open source, world-class, and free. KubeSentry is the experience around it: a curated ruleset tuned for low false positives, smart deduplication, a clean dashboard, email digests, multi-channel alerting, and triage + remediation guidance attached to every KubeSentry rule. Think of it as 'managed Falco you actually self-host.'",
            },
            {
              q: 'Is this a subscription?',
              a: 'No. Pay once, use forever — including all future updates. There is no renewal, no maintenance window, and no recurring charge of any kind. Your license is perpetual: it never expires, on any version.',
            },
            {
              q: 'Is the cluster count enforced?',
              a: "No. It's a licence term, not a technical limit — nothing in the collector counts your clusters, and a Solo key works anywhere you paste it. Enforcing it would mean every install reporting back to us, which is exactly the telemetry we promise never to send. You can verify that in the source. We'd rather trust you and keep the promise than police the count and break it.",
            },
            {
              q: 'Does it phone home?',
              a: "No. There is no KubeSentry server your cluster talks to — not for telemetry, not even for licensing, which is verified offline with Ed25519 signatures against a public key compiled into the collector. Your alerts and cluster data stay put; the one exception is notifications, which go only to the destinations you configure (your Slack, your inbox). Turn those off and the cluster can be fully air-gapped.",
            },
            {
              q: 'What about Wazuh / Tetragon / Kubescape?',
              a: "They're great tools. Wazuh is a full SIEM (heavyweight). Tetragon is powerful but low-level. Kubescape focuses on posture, not runtime. KubeSentry is opinionated and focused: real-time threat detection with zero setup pain. If you want to combine — go for it.",
            },
            {
              q: 'Can I try it before buying?',
              a: 'Yes. Every install starts with a 7-day free trial — the full product, no restrictions, no credit card. Install the chart and it just works; a banner in the dashboard tracks the trial. Add a license key when you are ready.',
            },
          ].map((item) => (
            <details class="group rounded-xl border border-line bg-bg-elevated/30 transition hover:border-line/80">
              <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 font-display font-medium text-text marker:hidden [&::-webkit-details-marker]:hidden">
                {item.q}
                <span class="shrink-0 font-mono text-accent transition-transform group-open:rotate-45">
                  +
                </span>
              </summary>
              <div class="border-t border-line px-5 py-4 text-sm leading-relaxed text-text-dim">
                {item.a}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-line py-14">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
        <div class="sm:col-span-2 md:col-span-1">
          <Logo />
          <p class="mt-4 max-w-xs text-sm leading-relaxed text-text-faint">
            Self-hosted runtime threat detection for Kubernetes.
          </p>
        </div>

        <div>
          <h3 class="mb-3 font-mono text-[11px] uppercase tracking-wider text-text-faint">
            Docs
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href={DOCS} class="text-text-dim transition hover:text-accent">
                Documentation
              </a>
            </li>
            <li>
              <a
                href={`${DOCS}/getting-started/installation/`}
                class="text-text-dim transition hover:text-accent"
              >
                Installation
              </a>
            </li>
            <li>
              <a
                href={`${DOCS}/getting-started/quickstart/`}
                class="text-text-dim transition hover:text-accent"
              >
                Quickstart
              </a>
            </li>
            <li>
              <a
                href={`${DOCS}/configuration/`}
                class="text-text-dim transition hover:text-accent"
              >
                Configuration
              </a>
            </li>
            <li>
              <a
                href={`${DOCS}/troubleshooting/`}
                class="text-text-dim transition hover:text-accent"
              >
                Troubleshooting
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="mb-3 font-mono text-[11px] uppercase tracking-wider text-text-faint">
            Product
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="#pricing" class="text-text-dim transition hover:text-accent">
                Pricing
              </a>
            </li>
            <li>
              <a
                href={`${DOCS}/licensing/`}
                class="text-text-dim transition hover:text-accent"
              >
                Licensing
              </a>
            </li>
            <li>
              <a
                href={`${DOCS}/architecture/`}
                class="text-text-dim transition hover:text-accent"
              >
                Architecture
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="mb-3 font-mono text-[11px] uppercase tracking-wider text-text-faint">
            Open artifacts
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href={GITHUB}
                target="_blank"
                rel="noopener"
                class="text-text-dim transition hover:text-accent"
              >
                GitHub
              </a>
            </li>
            <li>
              <a
                href="https://charts.kubesentry.io"
                target="_blank"
                rel="noopener"
                class="text-text-dim transition hover:text-accent"
              >
                Helm repository
              </a>
            </li>
            <li>
              <a
                href="https://twitter.com/kubesentry"
                target="_blank"
                rel="noopener"
                class="text-text-dim transition hover:text-accent"
              >
                Twitter
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div
        class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-line pt-6 font-mono text-xs text-text-faint sm:flex-row"
      >
        <span>© 2026 KubeSentry</span>
        <span>Payments handled by Lemon Squeezy, our merchant of record.</span>
      </div>
    </div>
  </footer>
</Layout>
