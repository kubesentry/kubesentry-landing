---
interface Props {
  them: string;
  themPrice: string;
  mine: string;
  minePrice: string;
}

const { them, themPrice, mine, minePrice } = Astro.props;
---

<div class="grid grid-cols-2 gap-4 rounded-lg border border-line bg-bg-elevated/30 p-4">
  <div class="border-r border-line pr-4">
    <div class="font-mono text-[10px] uppercase tracking-wider text-text-faint">
      Them
    </div>
    <div class="mt-1 font-display text-sm font-medium text-text-dim line-through decoration-danger/60 decoration-2">
      {them}
    </div>
    <div class="mt-1 font-mono text-xs text-text-faint">{themPrice}</div>
  </div>
  <div>
    <div class="font-mono text-[10px] uppercase tracking-wider text-accent">
      Us
    </div>
    <div class="mt-1 font-display text-sm font-semibold text-text">
      {mine}
    </div>
    <div class="mt-1 font-mono text-xs text-accent">{minePrice}</div>
  </div>
</div>
