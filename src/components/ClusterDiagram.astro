---
// Topology of what the chart actually installs, and what does (and doesn't)
// cross the cluster boundary.
//
// Built as markup rather than an exported image on purpose: it stays greppable
// when the topology changes, reflows on narrow screens, and is readable by a
// screen reader. Mirrors the ASCII diagram in the collector repo at
// website/docs/architecture.md — keep the two in step.
//
// Egress is drawn, not hidden: the notifier really does POST to Resend and to
// any Slack/Discord/Teams webhook you configure. Claiming "nothing ever leaves"
// would be false the moment notifications are switched on.

const nodes = [
  { name: 'node-1', pods: ['payments-api', 'redis'] },
  { name: 'node-2', pods: ['web', 'worker'] },
  { name: 'node-3', pods: ['api-gateway'] },
];

const collectorDoes = [
  ['aggregate', 'events from every node land in one place'],
  ['deduplicate', 'a crashlooping exploit becomes one alert, not 900'],
  ['store', 'SQLite on a PersistentVolume in your cluster'],
];
---

<section class="relative border-t border-line py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-14 max-w-3xl">
      <div class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">
        // what gets installed
      </div>
      <h2 class="text-balance font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
        Everything runs <span class="text-accent">inside your cluster</span>.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-text-dim">
        One Helm chart installs a Falco DaemonSet on every node, a router, and a single
        collector Deployment — that's every pod you'll see. Detection, storage, and the
        dashboard never talk to us. The only thing that ever leaves is an alert you
        explicitly configured, going to a destination you picked.
      </p>
    </div>

    <!-- Cluster boundary -->
    <div class="relative rounded-2xl border border-accent/25 bg-bg-elevated/20 p-5 sm:p-8">
      <div
        class="absolute -top-3 left-6 rounded-full border border-accent/30 bg-bg px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-accent"
      >
        your cluster · your infrastructure
      </div>

      <!-- Row 1: nodes, each with a Falco pod -->
      <div class="mt-2 grid gap-4 md:grid-cols-3">
        {
          nodes.map((node) => (
            <div class="rounded-xl border border-line bg-bg/50 p-4">
              <div class="mb-3 flex items-center justify-between">
                <span class="font-mono text-[11px] text-text-faint">{node.name}</span>
                <span class="font-mono text-[10px] uppercase tracking-wider text-text-faint">
                  node
                </span>
              </div>

              <div class="mb-3 flex flex-wrap gap-1.5">
                {node.pods.map((pod) => (
                  <span class="rounded border border-line bg-bg-elevated/60 px-2 py-1 font-mono text-[10px] text-text-dim">
                    {pod}
                  </span>
                ))}
              </div>

              <div class="rounded-lg border border-accent/30 bg-accent/5 px-3 py-2">
                <div class="font-mono text-[11px] text-accent">falco</div>
                <div class="mt-0.5 font-mono text-[10px] text-text-faint">
                  eBPF · reads the kernel
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <p class="mt-3 text-center font-mono text-[11px] text-text-faint">
        DaemonSet — one Falco pod per node, privileged, watching syscalls
      </p>

      <!-- Arrow down -->
      <div class="flex justify-center pt-3" aria-hidden="true">
        <div class="flex flex-col items-center">
          <div class="h-6 w-px bg-gradient-to-b from-transparent to-accent/40"></div>
          <span class="font-mono text-[10px] text-accent/70">events over HTTP</span>
          <div class="h-6 w-px bg-gradient-to-b from-accent/40 to-transparent"></div>
        </div>
      </div>

      <!-- Row 1.5: falcosidekick. Included because the chart really does deploy
           it — a reader checking `kubectl get pods` must find every box here. -->
      <div class="mx-auto max-w-md rounded-xl border border-line bg-bg/50 px-4 py-3 text-center">
        <div class="font-mono text-[11px] text-text">falcosidekick</div>
        <div class="mt-0.5 font-mono text-[10px] text-text-faint">
          routes Falco's output to the collector
        </div>
      </div>

      <!-- Arrow down -->
      <div class="flex justify-center py-3" aria-hidden="true">
        <div class="h-8 w-px bg-gradient-to-b from-accent/40 to-transparent"></div>
      </div>

      <!-- Row 2: collector -->
      <div class="rounded-xl border border-accent/30 bg-bg/60 p-5">
        <div class="mb-4 flex items-center justify-between">
          <span class="font-display text-sm font-semibold text-text">collector</span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-text-faint">
            deployment
          </span>
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          {
            collectorDoes.map(([label, detail]) => (
              <div class="rounded-lg border border-line bg-bg-elevated/40 px-3 py-2.5">
                <div class="font-mono text-[11px] text-accent">{label}</div>
                <div class="mt-1 text-[11px] leading-snug text-text-faint">{detail}</div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Arrow down -->
      <div class="flex justify-center py-3" aria-hidden="true">
        <div class="h-8 w-px bg-gradient-to-b from-accent/40 to-transparent"></div>
      </div>

      <!-- Row 3: surfaces -->
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-line bg-bg/50 p-4">
          <div class="font-mono text-[11px] text-text">dashboard</div>
          <div class="mt-1 text-[11px] leading-snug text-text-faint">
            Served by the collector. Reach it with
            <code class="text-text-dim">kubectl port-forward</code> — not exposed by default.
          </div>
        </div>
        <div class="rounded-xl border border-line bg-bg/50 p-4">
          <div class="font-mono text-[11px] text-text">notifier</div>
          <div class="mt-1 text-[11px] leading-snug text-text-faint">
            Instant on critical, daily digest for the rest. Off until you configure it.
          </div>
        </div>
      </div>
    </div>

    <!-- The one boundary crossing -->
    <div class="flex justify-center py-4" aria-hidden="true">
      <div class="flex flex-col items-center">
        <div class="h-6 w-px bg-gradient-to-b from-accent/40 to-warn/40"></div>
        <span class="font-mono text-[10px] text-warn">only if you configure it</span>
        <div class="h-6 w-px bg-gradient-to-b from-warn/40 to-transparent"></div>
      </div>
    </div>

    <div class="rounded-2xl border border-dashed border-line bg-bg-elevated/10 p-5 sm:p-6">
      <div class="mb-4 font-mono text-[10px] uppercase tracking-wider text-text-faint">
        outside your cluster
      </div>
      <div class="flex flex-wrap gap-2">
        {
          ['Email', 'Slack', 'Discord', 'Teams', 'Custom webhook'].map((dest) => (
            <span class="rounded-full border border-line bg-bg/60 px-3 py-1.5 font-mono text-[11px] text-text-dim">
              {dest}
            </span>
          ))
        }
      </div>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-text-dim">
        <span class="text-text">This is the only thing that ever leaves.</span> If you turn
        notifications on, the alert goes to the destination you configured — and nowhere
        else. There is no KubeSentry server in the picture: no telemetry, no phone-home,
        not even for licensing, which is verified offline against a key compiled into the
        binary. Air-gap the cluster and everything except these notifications still works.
      </p>
    </div>
  </div>
</section>
