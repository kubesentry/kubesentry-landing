---
// Email signup form — posts to /api/subscribe (Cloudflare Pages Function),
// which proxies to Buttondown using a server-side API key.
// See: functions/api/subscribe.js
---

<form
  id="signup-form"
  class="flex flex-col gap-3 sm:flex-row"
  novalidate
>
  <div class="relative flex-1">
    <label for="email" class="sr-only">Email address</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      placeholder="you@startup.com"
      class="w-full rounded-lg border border-line bg-bg-elevated/60 px-4 py-3 font-mono text-sm text-text placeholder-text-faint backdrop-blur-sm transition focus:border-accent/60 focus:outline-none focus:ring-2 focus:ring-accent/30 disabled:opacity-50"
    />
  </div>
  <button
    type="submit"
    id="signup-submit"
    class="group relative overflow-hidden rounded-lg bg-accent px-6 py-3 font-mono text-sm font-semibold text-bg transition-all hover:bg-accent-dim active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-50"
  >
    <span id="signup-btn-text" class="relative z-10 flex items-center justify-center gap-2">
      Get early access
      <span class="transition-transform group-hover:translate-x-0.5">→</span>
    </span>
  </button>
</form>

<div
  id="signup-success"
  class="mt-4 hidden rounded-lg border border-accent/40 bg-accent/5 px-4 py-3 font-mono text-sm text-accent"
>
  ✓ You're on the list. Watch your inbox for launch updates.
</div>

<div
  id="signup-already"
  class="mt-4 hidden rounded-lg border border-line bg-bg-elevated/60 px-4 py-3 font-mono text-sm text-text-dim"
>
  ✓ You're already on the list. Thanks!
</div>

<div
  id="signup-error"
  class="mt-4 hidden rounded-lg border border-danger/40 bg-danger/5 px-4 py-3 font-mono text-sm text-danger"
>
  <span id="signup-error-text">✗ Something went wrong. Try again in a moment.</span>
</div>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement;
  const btn = document.getElementById('signup-submit') as HTMLButtonElement;
  const btnText = document.getElementById('signup-btn-text');
  const success = document.getElementById('signup-success');
  const already = document.getElementById('signup-already');
  const error = document.getElementById('signup-error');
  const errorText = document.getElementById('signup-error-text');
  const emailInput = form?.elements.namedItem('email') as HTMLInputElement;

  function hideAll() {
    success?.classList.add('hidden');
    already?.classList.add('hidden');
    error?.classList.add('hidden');
  }

  function showError(msg: string) {
    if (errorText) errorText.textContent = `✗ ${msg}`;
    error?.classList.remove('hidden');
  }

  function setLoading(loading: boolean) {
    if (!btn || !btnText) return;
    btn.disabled = loading;
    emailInput.disabled = loading;
    btnText.innerHTML = loading
      ? '<span class="animate-pulse">Submitting...</span>'
      : 'Get early access <span class="transition-transform group-hover:translate-x-0.5">→</span>';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideAll();

    const email = emailInput?.value?.trim();

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('Please enter a valid email address.');
      return;
    }

    setLoading(true);

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json().catch(() => ({}));

      if (res.ok && data.ok) {
        // Hide the form, show success
        form.style.display = 'none';
        if (data.status === 'already-subscribed') {
          already?.classList.remove('hidden');
        } else {
          success?.classList.remove('hidden');
        }
        // Remember locally (purely UX — backend is source of truth)
        try {
          localStorage.setItem('kubesentry_signup', email);
        } catch {
          /* ignore storage errors (private mode, etc.) */
        }
      } else {
        setLoading(false);
        showError(data.error || 'Something went wrong. Please try again.');
      }
    } catch (err) {
      setLoading(false);
      showError('Network error. Check your connection and try again.');
    }
  });

  // If already signed up in this browser, show success state on load
  if (typeof window !== 'undefined') {
    try {
      if (localStorage.getItem('kubesentry_signup')) {
        form.style.display = 'none';
        already?.classList.remove('hidden');
      }
    } catch {
      /* ignore */
    }
  }
</script>
