---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'KubeSentry — self-hosted runtime threat detection for Kubernetes',
  description = 'Kernel-level runtime threat detection built on Falco, running entirely in your own cluster — no phone-home, no telemetry, your data never leaves. One-time license, 7-day free trial.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Crawlers won't resolve a relative og:image — it has to be absolute.
const ogImage = new URL('/og-image.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0b" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="KubeSentry" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="KubeSentry — runtime threat detection for Kubernetes, self-hosted. Install with: helm install kubesentry kubesentry/kubesentry"
    />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <meta
      property="twitter:image:alt"
      content="KubeSentry — runtime threat detection for Kubernetes, self-hosted. Install with: helm install kubesentry kubesentry/kubesentry"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Geist + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative overflow-x-hidden">
    <!-- Subtle scan-line decoration -->
    <div
      class="pointer-events-none fixed inset-0 z-[1] mix-blend-screen opacity-30"
      aria-hidden="true"
    >
      <div class="scan-line absolute left-0 right-0 h-32 animate-scan"></div>
    </div>

    <main class="relative z-10">
      <slot />
    </main>

    <style is:global>
      /* Smooth scroll & font defaults */
      html {
        font-family: 'Geist', system-ui, sans-serif;
      }
    </style>
  </body>
</html>
